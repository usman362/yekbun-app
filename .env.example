# YekBun end-user web app — environment variables.
#
# Copy this file to `.env.local` and adjust as needed. Vite only exposes vars prefixed
# with VITE_ to the browser — never put server secrets here.

# Backend base URL (Laravel API). Production points at api.appdash.yekbun.org; for local
# Laravel dev set this to http://localhost:8000/api (matches `php artisan serve`).
VITE_API_URL=https://api.appdash.yekbun.org/api
