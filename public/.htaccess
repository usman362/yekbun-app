# SPA history-mode rewrite — every non-asset request falls through to index.html
# so client-side routing (react-router) can handle deep links like /dashboard/wallet
# without the server returning 404. Asset files (anything with a dot extension) are
# served normally.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Don't rewrite real files / directories.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Everything else → SPA shell.
  RewriteRule . /index.html [L]
</IfModule>

# Long-cache hashed assets (Vite outputs filenames with content hashes). The index.html
# itself is never hashed, so keep its cache short / negotiated.
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# Gzip compression for text-based responses (huge win for the main JS bundle).
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>
